{
  "name": "ytm-enhancer",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "description": "A modular, cross-browser extension that enhances the YouTube Music web experience",
  "author": "John Gorman",
  "license": "MIT",
  "scripts": {
    "dev:chrome": "vite build --watch --mode development --config vite.config.chrome.ts",
    "dev:firefox": "vite build --watch --mode development --config vite.config.firefox.ts",
    "dev:edge": "vite build --watch --mode development --config vite.config.edge.ts",
    "dev:build": "pnpm run dev:build:chrome && pnpm run dev:build:firefox && pnpm run dev:build:edge",
    "dev:build:chrome": "vite build --mode development --config vite.config.chrome.ts",
    "dev:build:firefox": "vite build --mode development --config vite.config.firefox.ts",
    "dev:build:edge": "vite build --mode development --config vite.config.edge.ts",
    "build:chrome": "vite build --config vite.config.chrome.ts",
    "build:firefox": "vite build --config vite.config.firefox.ts",
    "build:edge": "vite build --config vite.config.edge.ts",
    "build": "pnpm run build:chrome && pnpm run build:firefox && pnpm run build:edge",
    "package": "pnpm run build && node scripts/package.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "css:dead": "node scripts/check-dead-popup-css.mjs",
    "data-role:check": "node scripts/check-data-role-uniqueness.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run format:check && pnpm run lint && pnpm run css:dead && pnpm run data-role:check && pnpm run typecheck && pnpm run test",
    "validate": "pnpm run format && pnpm run check && pnpm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.37",
    "eslint": "^10.0.2",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
